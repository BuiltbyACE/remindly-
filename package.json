{
  "name": "remindly",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "api:generate": "openapi-typescript ./src/openapi/remindly_openapi.json -o ./src/app/api/types.generated.ts",
    "api:fetch": "curl -o ./src/openapi/remindly_openapi.json http://localhost:8000/api/v1/openapi.json",
    "test:ci": "vitest run --coverage"
  },
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@ngrx/signals": "^21.1.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "ngx-echarts": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^21.2.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^28.0.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
