{
  "name": "remindly",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "ng lint",
    "prettier:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "prettier:write": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "api:generate": "openapi-typescript ./src/openapi/remindly_openapi.json -o ./src/app/api/types.generated.ts",
    "api:fetch": "curl -o ./src/openapi/remindly_openapi.json http://localhost:8000/api/v1/openapi.json"
  },
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@ngrx/signals": "^21.1.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "ngx-echarts": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^21.2.10",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitest/coverage-v8": "^4.1.6",
    "angular-eslint": "^19.3.0",
    "eslint": "^9.23.0",
    "jsdom": "^28.0.0",
    "openapi-typescript": "^7.13.0",
    "pa11y-ci": "^3.1.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^4.0.8"
  }
}
