{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "events-api",
      "urls": ["/api/v1/events/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "notifications-api",
      "urls": ["/api/v1/notifications/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "voice-api",
      "urls": ["/api/v1/voice/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "ai-api",
      "urls": ["/api/v1/ai/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "settings-api",
      "urls": ["/api/v1/settings/user/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "analytics-api",
      "urls": ["/api/v1/analytics/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 30,
        "maxAge": "1d",
        "timeout": "10s"
      }
    },
    {
      "name": "audit-api",
      "urls": ["/api/v1/audit/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1d",
        "timeout": "10s"
      }
    },
    {
      "name": "integrations-api",
      "urls": ["/api/v1/integrations/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 30,
        "maxAge": "1d",
        "timeout": "5s"
      }
    },
    {
      "name": "rbac-api",
      "urls": ["/api/v1/rbac/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "6h"
      }
    },
    {
      "name": "organizations-api",
      "urls": ["/api/v1/organizations/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "6h"
      }
    },
    {
      "name": "org-settings-api",
      "urls": ["/api/v1/settings/organization/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "1d"
      }
    },
    {
      "name": "reminder-policies-api",
      "urls": ["/api/v1/events/reminder-policies/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "1d"
      }
    }
  ]
}
